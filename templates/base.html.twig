<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Chalet{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<nav class="navbar navbar-expand-lg navbar-dark" style="background-color: #2C5F2D;">
    <div class="container">
        <a class="navbar-brand fw-bold" href="{{ path('app_home') }}">Chalet</a>

        <div class="navbar-nav ms-auto">
            {% if app.user %}
                <span class="nav-link text-white me-3">👤 {{ app.user.userIdentifier }}</span>
                {% if is_granted('ROLE_ADMIN') %}
                    <a class="btn btn-warning btn-sm me-2" href="#">Dashboard Admin</a>
                {% endif %}
                <a class="btn btn-outline-light btn-sm" href="{{ path('app_logout') }}">Se déconnecter</a>
            {% else %}
                <a class="nav-link text-white" href="{{ path('app_login') }}">Se connecter</a>
            {% endif %}
        </div>
    </div>
</nav>

<div class="container mt-4">
    {% block body %}{% endblock %}
</div>
</body>
</html>
