<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Chalet Gérardmer{% endblock %}</title>

    {{ importmap('app') }}
</head>
<body class="bg-light d-flex flex-column min-vh-100">

<nav class="navbar navbar-expand-lg navbar-custom sticky-top py-3">
    <div class="container">
        <a class="navbar-brand fw-bold fs-3" href="{{ path('app_home') }}">
            Chalet Gérardmer
        </a>

        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
            <i class="bi bi-list fs-1 text-dark"></i>
        </button>

        <div class="collapse navbar-collapse" id="navbarContent">
            <ul class="navbar-nav ms-auto align-items-center">

                {% if app.user %}
                    <li class="nav-item me-4">
                        <span class="nav-link"><i class="bi bi-person me-1"></i> {{ app.user.firstName }}</span>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_user_dashboard') }}">Mes Réservations</a>
                    </li>

                    {% if is_granted('ROLE_ADMIN') %}
                        <li class="nav-item me-3">
                            <a class="nav-link fw-bold" style="color: var(--vosges-bois);" href="{{ path('app_admin_dashboard') }}">Admin</a>
                        </li>
                    {% endif %}

                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_logout') }}">Déconnexion</a>
                    </li>

                {% else %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_login') }}">Espace Client</a>
                    </li>
                {% endif %}

            </ul>
        </div>
    </div>
</nav>

<div class="flex-grow-1">
    {% block body %}{% endblock %}
</div>

<footer class="py-5 mt-5 border-top" style="background-color: var(--vosges-sapin); color: white;">
    <div class="container text-center">
        <h4 class="mb-4" style="color: white;">Chalet Gérardmer.</h4>
        <small class="text-white-50">Copyright &copy; {{ 'now'|date('Y') }} - Projet TFE EAFC</small>
    </div>
</footer>

</body>
</html>
