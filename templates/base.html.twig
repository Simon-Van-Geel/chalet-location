<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Chalet Gérardmer{% endblock %}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        /* Petit ajustement pour la police du logo */
        .navbar-brand {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            letter-spacing: 1px;
        }
    </style>
</head>
<body class="bg-light d-flex flex-column min-vh-100">

<nav class="navbar navbar-expand-lg navbar-dark sticky-top shadow" style="background-color: #2C5F2D;">
    <div class="container">
        <a class="navbar-brand fw-bold fs-4" href="{{ path('app_home') }}">
            <i class="bi bi-house-door-fill me-2"></i>Chalet Gérardmer
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarContent">
            <ul class="navbar-nav ms-auto align-items-center">

                {% if app.user %}
                    <li class="nav-item me-3 text-white">
                        <i class="bi bi-person-circle me-1"></i>
                        <span class="fw-light">{{ app.user.userIdentifier }}</span>
                    </li>

                    {% if is_granted('ROLE_ADMIN') %}
                        <li class="nav-item me-2">
                            <a class="btn btn-warning btn-sm fw-bold shadow-sm" href="{{ path('app_admin_dashboard') }}">
                                <i class="bi bi-speedometer2 me-1"></i>Admin
                            </a>
                        </li>
                    {% endif %}

                    <li class="nav-item">
                        <a class="btn btn-outline-light btn-sm" href="{{ path('app_logout') }}">
                            <i class="bi bi-box-arrow-right me-1"></i>Déconnexion
                        </a>
                    </li>

                {% else %}
                    <li class="nav-item">
                        <a class="btn btn-light text-success fw-bold" href="{{ path('app_login') }}">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Se connecter
                        </a>
                    </li>
                {% endif %}

            </ul>
        </div>
    </div>
</nav>

<div class="container mt-4 flex-grow-1">
    {% block body %}{% endblock %}
</div>

<footer class="py-3 mt-5 bg-dark text-white-50 text-center">
    <small>Copyright &copy; {{ 'now'|date('Y') }} Chalet Gérardmer</small>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
