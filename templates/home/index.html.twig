{% extends 'base.html.twig' %}

{% block title %}Accueil - Chalet Gérardmer{% endblock %}

{% block body %}

    <section class="position-relative d-flex align-items-center justify-content-center"
             style="height: 80vh; background: linear-gradient(rgba(34, 58, 44, 0.4), rgba(34, 58, 44, 0.4)), url('{{ asset ('images/imageChalet1.png') }}'); background-size: cover; background-position: center; background-attachment: fixed;">
        <div class="text-center text-white px-3">
            <p class="text-uppercase tracking-widest mb-2" style="letter-spacing: 3px; font-size: 0.9rem;">Massif des Vosges</p>
            <h1 class="display-2 fw-normal mb-4" style="color: white;">Refuge Naturel</h1>
            <a href="#logements" class="btn btn-vosges mt-3">Découvrir le chalet</a>
        </div>
    </section>

    <section class="container py-5 my-5 text-center" style="max-width: 800px;">
        <h2 class="mb-4">L'Art de Vivre en Altitude</h2>
        <p class="lead" style="line-height: 1.8;">
            Découvrez notre chalet construit en bois massif, niché dans la forêt à deux pas du lac de Gérardmer.
            Pensé pour les familles et les groupes d'amis, cet espace modulable vous offre luxe, calme et authenticité.
        </p>
    </section>

    <section class="container my-5">
        <h2 class="text-center mb-4" style="color: var(--vosges-sapin);">Découvrez le chalet en images</h2>

        <div class="row g-4 justify-content-center">
            {# On boucle sur le tableau d'images envoyé par le contrôleur #}
            {% for image in images %}
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <div class="card border-0 shadow-sm h-100">
                        {# On utilise asset() pour générer le bon chemin vers le dossier public #}
                        <img src="{{ asset('uploads/gallery/' ~ image.fileName) }}"
                             alt="{{ image.altText }}"
                             class="card-img-top rounded"
                             style="height: 200px; object-fit: cover;">
                    </div>
                </div>
            {% else %}
                {# Ce message s'affiche automatiquement si le tableau d'images est vide #}
                <div class="col-12 text-center">
                    <p class="text-muted">Les photos du chalet arrivent très bientôt !</p>
                </div>
            {% endfor %}
        </div>
    </section>

    <section id="disponibilites" class="py-5 mt-5" style="background-color: var(--vosges-sapin); color: white;">
        <div class="container text-center py-5">
            <h2 class="mb-4" style="color: var(--vosges-brume);">Vérifier les disponibilités</h2>
            <p class="mb-5" style="color: rgba(255,255,255,0.7);">Sélectionnez vos dates pour un devis instantané.</p>

            <div {{ vue_component('BookingCalendar') }}
                class="mx-auto"
                style="max-width: 800px;">

                <div class="text-center py-4">
                    <div class="spinner-border text-light" role="status"></div>
                    <p class="mt-2 text+-white-50">Chargement de l'outil de réservation...</p>
                </div>
            </div>
        </div>
    </section>

    <section id="logements" class="container py-5">
        <div class="row g-5">
            {% for floor in floors %}
                <div class="col-md-6">
                    <div class="card-logement">
                        <div class="img-wrapper mb-4">
                            <img src="https://images.unsplash.com/photo-1542718610-a1d656d1884c?w=800&auto=format&fit=crop"
                                 class="img-fluid w-100"
                                 alt="{{ floor.name }}"
                                 style="height: 400px; object-fit: cover;">
                        </div>

                        <div class="d-flex justify-content-between align-items-baseline mb-2">
                            <h3 class="mb-0">{{ floor.name }}</h3>
                            <span class="fs-5" style="color: var(--vosges-bois); font-family: 'Playfair Display', serif;">{{ floor.basePrice }}€ <span class="fs-6 text-muted">/ nuit</span></span>
                        </div>

                        <p class="text-muted mb-4">{{ floor.description }}</p>

                        <div class="d-flex justify-content-between align-items-center border-top pt-3">
                            <span class="text-uppercase text-muted" style="font-size: 0.8rem; letter-spacing: 1px;">
                                <i class="bi bi-people me-2"></i>Jusqu'à {{ floor.capacity }} pers.
                            </span>
                            <a href="#" class="btn btn-vosges" style="padding: 8px 20px; font-size: 0.75rem;">Réserver</a>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12 text-center">
                    <p class="fs-4">Le catalogue est en cours de mise à jour.</p>
                </div>
            {% endfor %}
        </div>
    </section>

{% endblock %}
