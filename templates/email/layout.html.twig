{# templates/emails/layout.html.twig #}
{% apply inline_css(source('email/email.css')) %}
    <!DOCTYPE html>
    <html lang="">
    <head>
        <meta charset="UTF-8">
        <title></title>
    </head>
    <body>
    <div class="wrapper">
        <div class="container">
            <div class="header">
                <h1>{% block email_title %}Chalet Gérardmer{% endblock %}</h1>
            </div>

            <div class="content">
                {% block email_body %}{% endblock %}
            </div>

            <div class="footer">
                <p>© {{ "now"|date("Y") }} Chalet Gérardmer - TFE EAFC Namur</p>
            </div>
        </div>
    </div>
    </body>
    </html>
{% endapply %}
