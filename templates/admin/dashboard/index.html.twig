{% extends 'base.html.twig' %}

{% block title %}Administration{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
        <h1 class="h2">Tableau de bord</h1>
        <div class="btn-toolbar mb-2 mb-md-0">
            <div class="btn-group me-2">
                <button type="button" class="btn btn-sm btn-outline-secondary">Exporter</button>
                <button type="button" class="btn btn-sm btn-outline-secondary">Imprimer</button>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary mb-3 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Réservations</h5>
                    <p class="card-text display-6 fw-bold">12</p>
                    <p class="card-text"><small>En cours ce mois-ci</small></p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success mb-3 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Chiffre d'affaire</h5>
                    <p class="card-text display-6 fw-bold">2.4k€</p>
                    <p class="card-text"><small>+15% vs mois dernier</small></p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-warning mb-3 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Utilisateurs</h5>
                    <p class="card-text display-6 fw-bold">85</p>
                    <p class="card-text"><small>Inscrits sur le site</small></p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-danger mb-3 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">À valider</h5>
                    <p class="card-text display-6 fw-bold">3</p>
                    <p class="card-text"><small>Demandes en attente</small></p>
                </div>
            </div>
        </div>
    </div>

    <h3 class="mt-5">Dernières réservations</h3>
    <div class="table-responsive small card shadow-sm p-3">
        <table class="table table-striped table-hover align-middle">
            <thead>
            <tr>
                <th scope="col">#ID</th>
                <th scope="col">Client</th>
                <th scope="col">Logement</th>
                <th scope="col">Dates</th>
                <th scope="col">Statut</th>
                <th scope="col">Action</th>
            </tr>
            </thead>
            <tbody>
            <tr>
                <td>1001</td>
                <td>Jean Dupont</td>
                <td>Rez-de-Jardin</td>
                <td>12/02 - 14/02</td>
                <td><span class="badge bg-success">Confirmé</span></td>
                <td><button class="btn btn-sm btn-outline-primary">Voir</button></td>
            </tr>
            <tr>
                <td>1002</td>
                <td>Marie Curry</td>
                <td>Étage Panorama</td>
                <td>20/02 - 27/02</td>
                <td><span class="badge bg-warning text-dark">En attente</span></td>
                <td><button class="btn btn-sm btn-outline-primary">Voir</button></td>
            </tr>
            <tr>
                <td>1003</td>
                <td>Paul Martin</td>
                <td>Chalet Complet</td>
                <td>01/03 - 03/03</td>
                <td><span class="badge bg-secondary">Annulé</span></td>
                <td><button class="btn btn-sm btn-outline-primary">Voir</button></td>
            </tr>
            </tbody>
        </table>
    </div>
{% endblock %}
